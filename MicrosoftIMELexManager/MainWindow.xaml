<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MicrosoftIMELexManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MicrosoftIMELexManager"
    xmlns:pages="using:MicrosoftIMELexManager.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="微软拼音词库管理器">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
            Margin="36,15,36,20"
            BorderThickness="0">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 图标 -->
                <Rectangle Height="110" Width="110" VerticalAlignment="Center">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="Assets/字典和放大镜.png" Stretch="Uniform" />
                    </Rectangle.Fill>
                </Rectangle>

                <!-- 右侧：按钮 + 路径 + 条目数 -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Name="OpenFolderButton" Click="OpenFolder_Click"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8E5;" />
                                <TextBlock Text="打开文件夹" />
                            </StackPanel>
                        </Button>
                        <Button Name="SaveButton" Click="Save_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74E;" />
                                <TextBlock Text="保存" />
                            </StackPanel>
                        </Button>
                        <Button Name="RestoreButton" Click="Restore_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE777;" />
                                <TextBlock Text="恢复" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Name="CurrentFileText" Text="未打开文件"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Name="EntryCountText" Text=""
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Name="EntryCountDetailText" Text=""
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Padding="36,0,36,12" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0">
                <ListView x:Name="LibraryListBox"
                    SelectionChanged="LibraryListBox_SelectionChanged"
                    BorderThickness="0"
                    Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding EntryCount}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Border Grid.Column="1"
                Padding="0"
                BorderThickness="0">
                <Grid>
                    <Frame Name="LexFrame" Visibility="Collapsed" Background="Transparent" />
                    <Frame Name="IHFrame" Visibility="Collapsed" Background="Transparent" />
                    <Frame Name="UDLFrame" Visibility="Collapsed" Background="Transparent" />
                    <Frame Name="ViewerFrame" Visibility="Collapsed" Background="Transparent" />
                    <Border x:Name="EmptyContentState"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="14"
                        Padding="32">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="10" MaxWidth="360">
                            <FontIcon Glyph="&#xE8A5;" FontSize="28" HorizontalAlignment="Center" />
                            <TextBlock Text="请先打开文件夹"
                                Style="{ThemeResource TitleTextBlockStyle}"
                                HorizontalAlignment="Center" />
                            <TextBlock Text="选择包含词库文件的文件夹后，可在左侧切换不同词库。"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="WrapWholeWords"
                                HorizontalAlignment="Center"
                                TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>